# term = xterm-256color
term = xterm-ghostty
theme = Catppuccin Macchiato

# Font
font-family = JetBrainsMono Nerd Font
font-style = Regular
font-size = 14
font-thicken = true
font-feature = calt

# Scrollback (~500k lines, 50MB, lazy allocated per pane)
scrollback-limit = 50000000

# Mouse
copy-on-select = clipboard
mouse-hide-while-typing = true

# macOS
macos-option-as-alt = left

# Window
window-padding-x = 0
window-padding-y = 0
macos-titlebar-style = transparent

# Splits
unfocused-split-opacity = 0.7
confirm-close-surface = true

# Typography
bold-is-bright = true

# Quick terminal (Ctrl+` toggles system-wide)
quick-terminal-position = top
quick-terminal-animation-duration = 0
quick-terminal-autohide = true
keybind = global:ctrl+grave_accent=toggle_quick_terminal

# Shell integration
shell-integration-features = no-title

# Pane navigation: ctrl+shift+hjkl (vim-style, cross-platform)
keybind = ctrl+shift+h=goto_split:left
keybind = ctrl+shift+j=goto_split:down
keybind = ctrl+shift+k=goto_split:up
keybind = ctrl+shift+l=goto_split:right

# Tab navigation: cross-platform + macOS aliases
keybind = ctrl+shift+bracket_left=previous_tab
keybind = ctrl+shift+bracket_right=next_tab
keybind = super+shift+bracket_left=previous_tab
keybind = super+shift+bracket_right=next_tab

# Tab by index: Alt+1-9 (cross-platform, GNOME-safe — super+1-9 is intercepted by GNOME on Linux)
keybind = alt+1=goto_tab:1
keybind = alt+2=goto_tab:2
keybind = alt+3=goto_tab:3
keybind = alt+4=goto_tab:4
keybind = alt+5=goto_tab:5
keybind = alt+6=goto_tab:6
keybind = alt+7=goto_tab:7
keybind = alt+8=goto_tab:8
keybind = alt+9=goto_tab:9

# Splits: ctrl+shift+\ (vertical) and ctrl+shift+- (horizontal) — cross-platform
# Unbind super+d default (conflicts with GNOME show-desktop on Linux)
keybind = super+d=unbind
keybind = ctrl+shift+backslash=new_split:right
keybind = ctrl+shift+minus=new_split:down

# Resize split: ctrl+shift+alt+arrows (step) + equalize
keybind = ctrl+shift+alt+right=resize_split:right,20
keybind = ctrl+shift+alt+left=resize_split:left,20
keybind = ctrl+shift+alt+up=resize_split:up,20
keybind = ctrl+shift+alt+down=resize_split:down,20
keybind = ctrl+shift+alt+zero=equalize_splits

# Tab reorder
keybind = ctrl+shift+comma=move_tab:-1
keybind = ctrl+shift+period=move_tab:1

# Tab title
keybind = ctrl+shift+alt+t=prompt_tab_title

# New tab: Ctrl+Shift+T cross-platform (Cmd+T already default)
keybind = ctrl+shift+t=new_tab

# Close pane: Ctrl+Shift+W cross-platform (Cmd+W already default)
keybind = ctrl+shift+w=close_surface

# Close tab: Ctrl+Shift+Q cross-platform
keybind = ctrl+shift+q=close_tab:this

# Zoom: Ctrl+Shift+Z (cross-platform, all terminals)
keybind = ctrl+shift+z=toggle_split_zoom

# Unbind super+n default (conflicts with GNOME notification center on Linux)
keybind = super+n=unbind

# Tmux CSI sequences: Ctrl+Super+digit (replaces command+digit — Win+1-9 conflicts with GNOME)
keybind = ctrl+super+digit1=csi:49;9u
keybind = ctrl+super+digit2=csi:50;9u
keybind = ctrl+super+digit3=csi:51;9u
keybind = ctrl+super+digit4=csi:52;9u
keybind = ctrl+super+digit5=csi:53;9u
keybind = ctrl+super+digit6=csi:54;9u
keybind = ctrl+super+digit7=csi:55;9u
keybind = ctrl+super+digit8=csi:56;9u
keybind = ctrl+super+digit9=csi:57;9u
keybind = ctrl+super+digit0=csi:48;9u

# Eliminates dark halo/artifact around colored text edges on dark themes like Catppuccin
alpha-blending = linear-corrected
